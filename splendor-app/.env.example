# Environment Variables

# The URL of the socket server. 
# In production, this defaults to http://<hostname>:3001
# Set this if your server is on a different port or behind a reverse proxy.
# VITE_SOCKET_URL=http://your-server-ip:3001
# VITE_SOCKET_URL=/ (if using a reverse proxy)
VITE_SOCKET_URL=http://localhost:3001
